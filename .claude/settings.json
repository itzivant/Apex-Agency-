{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(date *)",
      "Bash(find leads/*)",
      "Bash(find outreach/*)",
      "Bash(find contracts/*)",
      "Bash(find clients/*)",
      "Bash(jq *)",
      "Bash(./scripts/*)",
      "WebSearch",
      "WebFetch",
      "Skill(qualify-lead)",
      "Skill(draft-contract)",
      "Skill(send-outreach)",
      "Skill(schedule-followup)",
      "Agent(orchestrator)",
      "Agent(lead-hunter)",
      "Agent(lead-qualifier)",
      "Agent(outreach-writer)",
      "Agent(appointment-booker)",
      "Agent(contract-drafter)",
      "Agent(follow-up-manager)",
      "Agent(client-onboarder)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/log-activity.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/log-subagent-finish.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/guard-no-send.sh"
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 90
}
